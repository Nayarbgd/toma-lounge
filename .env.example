# =============================================================================
# Toma Lounge — Required Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# On Replit, set these as Secrets in the project's Secrets panel.
# On Vercel/Railway/Render, set them as environment variables in the dashboard.

# --- Supabase (required) ---
# Find these in your Supabase project: Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# --- Database (internal PostgreSQL, Replit-managed — not used for reservations after Supabase migration) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Session secret (used by Express session middleware) ---
SESSION_SECRET=a-long-random-string-used-for-signing-sessions
