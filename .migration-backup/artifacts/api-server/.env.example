# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email notifications (Resend)
# Get your API key at https://resend.com/api-keys
# If you don't have a verified sending domain yet, the "from" address must use
# Resend's shared domain: onboarding@resend.dev (works out of the box).
# To use your own domain (e.g. notifications@tomalounge.com), verify it at:
# https://resend.com/domains
RESEND_API_KEY=re_your_resend_api_key

# The restaurant owner's email — all new reservation alerts are sent here
OWNER_EMAIL=owner@yourdomain.com

# Optional: URL of the admin dashboard shown in notification emails
# Defaults to a placeholder if not set
ADMIN_DASHBOARD_URL=https://your-app.replit.app/admin
